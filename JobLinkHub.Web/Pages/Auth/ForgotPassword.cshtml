@page
@model JobLinkHub.Web.Pages.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
}

<section class="forgot-password-page">
    <div class="container forgot-password-wrapper">
        <div class="forgot-password-card">
            <div class="forgot-password-top">
                <span class="forgot-eyebrow">Account recovery</span>
                <h1>Forgot your password?</h1>
                <p>
                    Enter the email address linked to your account and we’ll send you a password reset link.
                </p>
            </div>

            <form class="forgot-password-form">
                <div class="form-group">
                    <label for="resetEmail">Email address</label>
                    <input id="resetEmail" type="email" placeholder="example@example.com" />
                </div>

                <button type="submit" class="forgot-submit-btn">Send Reset Link</button>
            </form>

            <div class="forgot-password-links">
                <a asp-page="/Auth/Login">Back to Login</a>
                <span>•</span>
                <a asp-page="/Auth/ChooseRole">Create Account</a>
            </div>
        </div>
    </div>
</section>