@page
@model JobLinkHub.Web.Pages.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_AuthLayout";
}

<section class="auth-page">
    <div class="auth-container">
        <div class="auth-grid">
            <div class="auth-showcase">
                <h1>Reset your <span style="color:var(--color-accent);">password</span> and get back on track.</h1>
                <p>Enter your registered email and we'll send you a secure link to create a new password.</p>
            </div>
            <div class="auth-card">
                <h2 class="auth-card-title">Forgot password?</h2>
                <p class="auth-card-subtitle">Enter your email and we'll send a reset link.</p>

                @if (Model.EmailSent)
                {
                    <div class="alert alert-success" style="margin-bottom:1.2rem;">
                        <i class="fa-solid fa-circle-check"></i>
                        If that email is registered, a reset link has been sent. Check your inbox.
                    </div>
                    <div class="form-bottom-text">
                        <a asp-page="/Auth/Login">Back to Login</a>
                    </div>
                }
                else
                {
                    @if (Model.ErrorMessage != null)
                    {
                        <div class="alert alert-danger" style="margin-bottom:1rem;">@Model.ErrorMessage</div>
                    }
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <div class="form-field">
                            <label for="resetEmail">Email address</label>
                            <input id="resetEmail" name="Email" type="email" placeholder="example@example.com" required />
                        </div>
                        <button type="submit" class="form-submit-btn">Send Reset Link</button>
                    </form>
                    <div class="form-bottom-text">
                        Remember your password? <a asp-page="/Auth/Login">Back to Login</a>
                    </div>
                    <div class="form-bottom-text" style="margin-top:0.5rem;">
                        No account? <a asp-page="/Auth/ChooseRole">Create one</a>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
