@page
@model JobLinkHub.Web.Pages.Auth.RegisterCandidateModel
@{
    ViewData["Title"] = "Join as a Job Seeker";
    Layout = "_AuthLayout";
}

<section class="auth-page">
    <div class="auth-container">
        <div class="auth-grid">
            <div class="auth-showcase">
                <h1>Build your <span style="color:var(--color-accent);">skill-first profile</span> and get matched.</h1>
                <p>Create your free account, showcase your abilities, and connect with employers looking for your skills.</p>
            </div>
            <div class="auth-card">
                <h2 class="auth-card-title">Create your account</h2>
                <p class="auth-card-subtitle">Join as a Job Seeker on JobLink Hub.</p>

                <form method="post">
                    @Html.AntiForgeryToken()
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger">@Model.ErrorMessage</div>
                    }
                    <div asp-validation-summary="All" style="color:#ef4444;font-size:0.85rem;margin-bottom:0.75rem;padding:0.5rem 0.75rem;border-radius:6px;background:rgba(239,68,68,0.08);display:@(ViewData.ModelState.IsValid ? "none" : "block");"></div>
                    <div class="form-field-row">
                        <div class="form-field">
                            <label>First name</label>
                            <input name="FirstName" type="text" value="@Model.FirstName" placeholder="Jane" required />
                        </div>
                        <div class="form-field">
                            <label>Last name</label>
                            <input name="LastName" type="text" value="@Model.LastName" placeholder="Doe" required />
                        </div>
                    </div>
                    <div class="form-field">
                        <label>Email address</label>
                        <input name="Email" type="email" value="@Model.Email" placeholder="jane@example.com" required />
                    </div>
                    <div class="form-field">
                        <label>Password</label>
                        <input name="Password" type="password" placeholder="Min 8 chars, 1 uppercase, 1 number" required />
                    </div>
                    <div class="form-field">
                        <label>Confirm password</label>
                        <input name="ConfirmPassword" type="password" placeholder="Repeat your password" required />
                    </div>
                    <div class="form-field">
                        <label>Location <span style="color:var(--color-text-muted);">(optional)</span></label>
                        <input name="Location" type="text" value="@Model.Location" placeholder="e.g. Kigali, Rwanda" />
                    </div>
                    <div class="form-field">
                        <label>Career interest <span style="color:var(--color-text-muted);">(optional)</span></label>
                        <input name="CareerInterest" type="text" value="@Model.CareerInterest" placeholder="e.g. Software Development, Design..." />
                    </div>
                    <button type="submit" class="form-submit-btn">Create Account</button>
                </form>

                @section Scripts {
                    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
                }
                <div class="form-bottom-text">
                    Already have an account? <a asp-page="/Auth/Login">Log in</a>
                </div>
            </div>
        </div>
    </div>
</section>
