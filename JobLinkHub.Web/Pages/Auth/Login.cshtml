@page
@model JobLinkHub.Web.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = "_AuthLayout";
}

<section class="auth-page">
    <div class="auth-container">
        <div class="auth-grid">
            <div class="auth-showcase">
                <h1>Continue where <span style="color:var(--color-accent);">opportunity</span> meets potential.</h1>
                <p>
                    Sign in to manage your profile, track opportunities, review applicants,
                    and keep building meaningful career connections on JobLink Hub.
                </p>
            </div>
            <div class="auth-card">
                <h2 class="auth-card-title">Log in</h2>
                <p class="auth-card-subtitle">Enter your details to access your account.</p>

                @if (TempData["SuccessMessage"] is string successMsg)
                {
                    <div class="alert alert-success" style="margin-bottom:1rem;">
                        <i class="fa-solid fa-circle-check"></i> @successMsg
                    </div>
                }
                <form method="post">
                    @Html.AntiForgeryToken()
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger">@Model.ErrorMessage</div>
                    }
                    <div class="form-field">
                        <label for="email">Email address</label>
                        <input id="email" name="Email" type="email" value="@Model.Email" placeholder="example@example.com" required />
                    </div>
                    <div class="form-field">
                        <div class="form-row-between">
                            <label for="password">Password</label>
                            <a asp-page="/Auth/ForgotPassword" class="form-link">Forgot password?</a>
                        </div>
                        <input id="password" name="Password" type="password" placeholder="Enter your password" required />
                    </div>
                    <div style="margin-bottom: 1rem;">
                        <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.88rem; cursor: pointer;">
                            <input type="checkbox" name="RememberMe" value="true" />
                            <span>Remember me</span>
                        </label>
                    </div>
                    <button type="submit" class="form-submit-btn">Sign In</button>
                </form>
                <div class="form-divider"><span>or</span></div>
                <button type="button" class="form-submit-btn" style="background: var(--color-bg); color: var(--color-text); border: 1px solid var(--color-border);">
                    Continue with Google
                </button>
                <div class="form-bottom-text">
                    Don't have an account? <a asp-page="/Auth/ChooseRole">Create one</a>
                </div>
            </div>
        </div>
    </div>
</section>