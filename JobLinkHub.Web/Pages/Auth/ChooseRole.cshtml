@page
@model JobLinkHub.Web.Pages.ChooseRoleModel
@{
    ViewData["Title"] = "Choose Role";
    Layout = "_AuthLayout";
}

<section class="auth-page" style="padding: 3rem 0;">
    <div class="auth-container">
        <div style="text-align: center; margin-bottom: 2.5rem;">
            <h1 style="font-family: 'Outfit', sans-serif; font-size: 2.4rem; font-weight: 800; color: #fff; margin-bottom: 0.6rem;">
                Choose how you want to use <span style="color: var(--color-accent);">JobLink Hub</span>
            </h1>
            <p style="color: rgba(255,255,255,0.55); font-size: 1rem; max-width: 560px; margin: 0 auto;">
                Select the role that best matches how you will use the platform.
            </p>
            <div class="form-bottom-text" style="color: rgba(255,255,255,0.65); margin-top: 1rem;">
                Already have an account? <a asp-page="/Auth/Login" style="color: var(--color-accent); font-weight: 700;">Log in</a>
            </div>
        </div>

        <div class="role-cards-grid" style="max-width: 760px; margin: 0 auto;">
            <div class="role-card">
                <div class="role-icon" style="background: #dbeafe; color: #2563eb;"><i class="fa-solid fa-user"></i></div>
                <h2>Join as a Job Seeker</h2>
                <p>Build a skill-first profile, validate your abilities, and connect to jobs, internships, mentorships, and gigs.</p>
                <ul class="role-features">
                    <li>Showcase skills and evidence</li>
                    <li>Apply for relevant opportunities</li>
                    <li>Track matches and applications</li>
                </ul>
                <a asp-page="/Auth/RegisterCandidate" class="role-btn">Continue as Job Seeker</a>
            </div>
            <div class="role-card" style="border-color: var(--color-accent); position: relative;">
                <span class="badge badge-green" style="position: absolute; top: 1rem; right: 1rem;">Recommended</span>
                <div class="role-icon" style="background: #dcfce7; color: #16a34a;"><i class="fa-solid fa-building"></i></div>
                <h2>Join as an Employer</h2>
                <p>Create a company profile, post opportunities, manage applicants, and discover qualified emerging talent.</p>
                <ul class="role-features">
                    <li>Create and manage company profile</li>
                    <li>Post jobs, internships, and more</li>
                    <li>Review and manage applicants</li>
                </ul>
                <a asp-page="/Auth/RegisterEmployer" class="role-btn role-btn-filled">Continue as Employer</a>
            </div>
        </div>
    </div>
</section>