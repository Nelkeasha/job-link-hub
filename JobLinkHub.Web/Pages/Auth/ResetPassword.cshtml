@page
@model JobLinkHub.Web.Pages.ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = "_AuthLayout";
}

<section class="auth-page">
    <div class="auth-container">
        <div class="auth-grid">
            <div class="auth-showcase">
                <h1>Create a new <span style="color:var(--color-accent);">password</span> for your account.</h1>
                <p>Choose a strong password you'll remember. You'll be redirected to login once it's set.</p>
            </div>
            <div class="auth-card">
                <h2 class="auth-card-title">Reset password</h2>
                <p class="auth-card-subtitle">Enter and confirm your new password below.</p>

                @if (Model.InvalidLink)
                {
                    <div class="alert alert-danger" style="margin-bottom:1rem;">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        This reset link is invalid or has expired. Please request a new one.
                    </div>
                    <a asp-page="/Auth/ForgotPassword" class="form-submit-btn" style="display:block;text-align:center;text-decoration:none;">Request New Link</a>
                }
                else
                {
                    @if (Model.ErrorMessage != null)
                    {
                        <div class="alert alert-danger" style="margin-bottom:1rem;">@Model.ErrorMessage</div>
                    }
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Email" value="@Model.Email" />
                        <input type="hidden" name="Token" value="@Model.Token" />
                        <div class="form-field">
                            <label for="newPassword">New password</label>
                            <input id="newPassword" name="NewPassword" type="password" placeholder="Enter your new password" required minlength="8" />
                        </div>
                        <div class="form-field">
                            <label for="confirmPassword">Confirm password</label>
                            <input id="confirmPassword" name="ConfirmPassword" type="password" placeholder="Re-enter your new password" required minlength="8" />
                        </div>
                        <button type="submit" class="form-submit-btn">Reset Password</button>
                    </form>
                }

                <div class="form-bottom-text">
                    <a asp-page="/Auth/Login">Back to Login</a>
                </div>
            </div>
        </div>
    </div>
</section>