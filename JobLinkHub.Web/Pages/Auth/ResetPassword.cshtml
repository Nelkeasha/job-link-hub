@page
@model JobLinkHub.Web.Pages.ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
}

<section class="reset-password-page">
    <div class="container reset-password-wrapper">
        <div class="reset-password-card">
            <div class="reset-password-top">
                <span class="reset-eyebrow">Set a new password</span>
                <h1>Reset your password</h1>
                <p>
                    Create a new password for your account. Make sure it is strong and easy for you to remember.
                </p>
            </div>

            <form class="reset-password-form">
                <div class="form-group">
                    <label for="newPassword">New password</label>
                    <input id="newPassword" type="password" placeholder="Enter your new password" />
                </div>

                <div class="form-group">
                    <label for="confirmPassword">Confirm password</label>
                    <input id="confirmPassword" type="password" placeholder="Re-enter your new password" />
                </div>

                <button type="submit" class="reset-submit-btn">Reset Password</button>
            </form>

            <div class="reset-password-links">
                <a asp-page="/Auth/Login">Back to Login</a>
            </div>
        </div>
    </div>
</section>