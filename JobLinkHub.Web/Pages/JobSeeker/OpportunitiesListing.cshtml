@page
@model JobLinkHub.Web.Pages.JobSeeker.OpportunitiesListingModel
@{
    ViewData["Title"] = "Browse Opportunities";
    Layout = "_DashboardLayout";
    ViewData["DashboardRole"] = "Candidate";
    ViewData["ActivePage"] = "";
}

<div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:1rem;margin-bottom:1.5rem;">
    <div>
        <p class="dash-header-label">JOB LISTINGS</p>
        <h1 class="dash-greeting">Browse Opportunities</h1>
        <p class="dash-greeting-sub">Find jobs, internships, freelance work, and more.</p>
    </div>
</div>

<!-- Search / Filter -->
<form method="get" class="dash-filter-bar" style="margin-bottom:1.5rem;">
    <div class="filter-group">
        <label>Search</label>
        <input asp-for="SearchQ" type="text" placeholder="Title or skill..." />
    </div>
    <div class="filter-group">
        <label>Type</label>
        <select asp-for="FilterType">
            <option value="">All Types</option>
            <option>Job</option>
            <option>Internship</option>
            <option>Freelance</option>
            <option>Mentorship</option>
        </select>
    </div>
    <div class="filter-group">
        <label>Location</label>
        <input asp-for="FilterLocation" type="text" placeholder="City..." />
    </div>
    <button type="submit" class="filter-btn"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
</form>

@if (!Model.Opportunities.Any())
{
    <div class="dash-cta-card">
        <div class="cta-icon"><i class="fa-solid fa-briefcase"></i></div>
        <h3>No opportunities found</h3>
        <p>Try adjusting your filters or check back later for new postings.</p>
    </div>
}
else
{
    <div class="jobs-grid">
        @foreach (var o in Model.Opportunities)
        {
            var avatarColors = new[] { "job-avatar-blue","job-avatar-purple","job-avatar-green","job-avatar-amber" };
            var colorCls = avatarColors[Math.Abs(o.Title.GetHashCode()) % avatarColors.Length];
            <div class="job-card">
                <div class="job-avatar @colorCls">@(o.Title.Length > 0 ? o.Title[0].ToString().ToUpper() : "?")</div>
                <div class="job-info">
                    <div class="job-title">@o.Title</div>
                    <div class="job-company">@o.CompanyName</div>
                    <div class="job-meta">
                        <span class="job-meta-pill"><i class="fa-solid fa-tag"></i> @o.OpportunityType</span>
                        @if (!string.IsNullOrEmpty(o.Location))
                        {
                            <span class="job-meta-pill"><i class="fa-solid fa-location-dot"></i> @o.Location</span>
                        }
                        @if (o.Deadline.HasValue)
                        {
                            <span class="job-meta-pill"><i class="fa-regular fa-clock"></i> Due @o.Deadline.Value.ToString("MMM dd")</span>
                        }
                    </div>
                </div>
                <div class="job-right">
                    <a href="/JobSeeker/OpportunityDetails?id=@o.Id" class="job-apply-btn">
                        View <i class="fa-solid fa-arrow-right"></i>
                    </a>
                    <form method="post" asp-page-handler="ToggleSave" style="margin:0;">
                        <input type="hidden" name="opportunityId" value="@o.Id" />
                        @{
                            bool isSaved = Model.SavedIds.Contains(o.Id);
                        }
                        <button type="submit" class="job-save-btn @(isSaved ? "saved" : "")"
                                title="@(isSaved ? "Remove from saved" : "Save job")"
                                style="background:none;border:none;cursor:pointer;padding:0;">
                            <i class="fa-@(isSaved ? "solid" : "regular") fa-heart" style="@(isSaved ? "color:#ef4444;" : "")"></i>
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}
