@page
@model JobLinkHub.Web.Pages.JobSeeker.MyApplicationsModel
@{
    ViewData["Title"] = "Applied Jobs";
    Layout = "_DashboardLayout";
    ViewData["DashboardRole"] = "Candidate";
    ViewData["UserName"] = "Candidate";
    ViewData["ActivePage"] = "AppliedJobs";
}

<div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;margin-bottom:1.5rem;">
    <div>
        <h1 class="dash-greeting" style="font-size:1.4rem;">Applied Jobs</h1>
        <p class="dash-greeting-sub">Track your applications and their statuses.</p>
    </div>
    <a href="/JobSeeker/OpportunitiesListing" class="cta-btn"><i class="fa-solid fa-magnifying-glass"></i> Find More</a>
</div>

<!-- Filter tabs -->
<div style="display:flex;gap:0.4rem;margin-bottom:1.2rem;flex-wrap:wrap;">
    @foreach (var status in new[] { ("", "All"), ("PENDING", "Pending"), ("SHORTLISTED", "Shortlisted"), ("ACCEPTED", "Accepted"), ("REJECTED", "Rejected"), ("WITHDRAWN", "Withdrawn") })
    {
        bool isActive = Model.FilterStatus == status.Item1 || (string.IsNullOrEmpty(Model.FilterStatus) && status.Item1 == "");
        <a href="?FilterStatus=@status.Item1" class="jobs-tab @(isActive ? "active" : "")">@status.Item2</a>
    }
</div>

@if (!Model.Applications.Any())
{
    <div class="dash-panel"><div class="panel-empty">No applications found.</div></div>
}

<div style="display:flex;flex-direction:column;gap:0.8rem;">
    @foreach (var a in Model.Applications)
    {
        var badgeCls = a.Status?.ToUpper() switch {
            "ACCEPTED" => "badge-green",
            "SHORTLISTED" => "badge-green",
            "REJECTED" => "badge-red",
            "WITHDRAWN" => "badge-gray",
            _ => "badge-amber"
        };
        var statusDisplay = a.Status?.ToUpper() switch {
            "PENDING" => "Pending",
            "SHORTLISTED" => "Shortlisted",
            "ACCEPTED" => "Accepted",
            "REJECTED" => "Rejected",
            "WITHDRAWN" => "Withdrawn",
            _ => a.Status
        };
        <div class="dash-panel" style="padding:1rem 1.3rem;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;">
                <div style="flex:1;">
                    <h3 style="font-weight:700;font-size:1rem;margin-bottom:0.2rem;">@a.OpportunityTitle</h3>
                    <p style="color:var(--color-accent);font-weight:600;font-size:0.88rem;margin-bottom:0.3rem;">@a.CompanyName</p>
                    <p style="font-size:0.78rem;color:var(--color-text-muted);">Applied @a.ApplicationDate.ToString("MMM dd, yyyy")</p>
                    @if (!string.IsNullOrEmpty(a.CoverLetter))
                    {
                        <p style="font-size:0.82rem;color:var(--color-text-light);font-style:italic;margin-top:0.4rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                            "@a.CoverLetter"
                        </p>
                    }
                </div>
                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:0.5rem;margin-left:1rem;">
                    <span class="badge @badgeCls">@statusDisplay</span>
                    <a href="/JobSeeker/OpportunityDetails?id=@a.OpportunityId" class="table-action-link">View job</a>
                    @if (a.Status?.ToUpper() == "PENDING")
                    {
                        <form method="post" asp-page-handler="Withdraw" style="margin:0;">
                            <input type="hidden" name="appId" value="@a.Id" />
                            <button type="submit" class="table-action-link table-action-danger" style="background:none;border:none;cursor:pointer;font-family:inherit;padding:0;">
                                Withdraw
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    }
</div>