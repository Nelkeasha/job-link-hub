@page
@model JobLinkHub.Web.Pages.JobSeeker.SavedJobsModel
@{
    ViewData["Title"] = "Saved Jobs";
    Layout = "_DashboardLayout";
    ViewData["DashboardRole"] = "Candidate";
    ViewData["UserName"] = "Candidate";
    ViewData["ActivePage"] = "SavedJobs";
}

<div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;margin-bottom:1.5rem;">
    <div>
        <h1 class="dash-greeting" style="font-size:1.4rem;">Saved Jobs</h1>
        <p class="dash-greeting-sub">Jobs you've bookmarked for later.</p>
    </div>
    <a href="/JobSeeker/OpportunitiesListing" class="cta-btn"><i class="fa-solid fa-magnifying-glass"></i> Browse More</a>
</div>

@if (!Model.SavedJobs.Any())
{
    <div class="dash-panel">
        <div class="panel-empty">
            <p>No saved jobs yet.</p>
            <a href="/JobSeeker/OpportunitiesListing" class="cta-btn" style="margin-top:1rem;">Browse Opportunities</a>
        </div>
    </div>
}

<div style="display:flex;flex-direction:column;gap:0.8rem;">
    @foreach (var j in Model.SavedJobs)
    {
        <div class="dash-panel" style="padding:1rem 1.3rem;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;">
                <div style="flex:1;">
                    <div style="display:flex;gap:0.5rem;margin-bottom:0.4rem;">
                        <span class="badge badge-blue">@j.OpportunityType</span>
                    </div>
                    <h3 style="font-weight:700;font-size:1rem;margin-bottom:0.2rem;">@j.Title</h3>
                    <p style="color:var(--color-accent);font-weight:600;font-size:0.88rem;margin-bottom:0.2rem;">
                        @j.CompanyName @(j.Location != null ? "· " + j.Location : "")
                    </p>
                    @if (j.Deadline.HasValue)
                    {
                        <p style="font-size:0.78rem;color:#f59e0b;">Deadline: @j.Deadline.Value.ToString("MMM dd, yyyy")</p>
                    }
                </div>
                <div style="display:flex;flex-direction:column;gap:0.5rem;margin-left:1rem;align-items:flex-end;">
                    <a href="/JobSeeker/OpportunityDetails?id=@j.OpportunityId" class="table-action-link">View →</a>
                    <a href="/JobSeeker/Apply?id=@j.OpportunityId" class="cta-btn" style="padding:0.4rem 0.9rem;font-size:0.78rem;">Apply</a>
                    <form method="post" asp-page-handler="Remove" style="margin:0;">
                        <input type="hidden" name="opportunityId" value="@j.OpportunityId" />
                        <button type="submit" class="table-action-link table-action-danger" style="background:none;border:none;cursor:pointer;font-family:inherit;padding:0;">Remove</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>