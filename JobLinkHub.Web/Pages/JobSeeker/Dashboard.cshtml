@page
@model JobLinkHub.Web.Pages.JobSeeker.DashboardModel
@{
    ViewData["Title"] = "My Dashboard";
    Layout = "_DashboardLayout";
    ViewData["DashboardRole"] = "Candidate";
    ViewData["UserName"] = Model.FullName;
    ViewData["ActivePage"] = "Overview";
}

<!-- Header -->
<div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.5rem;">
    <div>
        <p class="dash-header-label">CANDIDATE PORTAL</p>
        <h1 class="dash-greeting">Hello, @(string.IsNullOrEmpty(Model.FullName) ? "there" : Model.FullName.Split(' ')[0])!</h1>
        <p class="dash-greeting-sub">Keep exploring. Let's find your dream job today.</p>
    </div>
    <a href="#" class="dash-premium-banner">
        <div class="dash-premium-icon"><i class="fa-solid fa-star"></i></div>
        <div class="dash-premium-text">
            <strong>PREMIUM PLAN</strong>
            <span>Upgrade to Pro</span>
        </div>
        <i class="fa-solid fa-chevron-right" style="color: var(--color-text-muted); margin-left: auto;"></i>
    </a>
</div>

<!-- Stats -->
<div class="dash-stats-row">
    <div class="dash-stat-card">
        <div class="stat-icon stat-icon-blue"><i class="fa-solid fa-briefcase"></i></div>
        <div class="stat-info">
            <p class="stat-label">Applied Jobs</p>
            <p class="stat-value">@Model.TotalApplications</p>
        </div>
    </div>
    <div class="dash-stat-card">
        <div class="stat-icon stat-icon-green"><i class="fa-solid fa-circle-check"></i></div>
        <div class="stat-info">
            <p class="stat-label">Shortlisted</p>
            <p class="stat-value">@Model.ShortlistedCount</p>
        </div>
    </div>
    <div class="dash-stat-card">
        <div class="stat-icon stat-icon-amber"><i class="fa-solid fa-bookmark"></i></div>
        <div class="stat-info">
            <p class="stat-label">Saved Jobs</p>
            <p class="stat-value">@Model.SavedJobsCount</p>
        </div>
    </div>
</div>

<!-- Panels -->
<div class="dash-panels">
    <!-- Recent Applications -->
    <div class="dash-panel">
        <div class="panel-header">
            <h2 class="panel-title">Recent Applications</h2>
            <a href="/JobSeeker/MyApplications" class="panel-link">VIEW ALL</a>
        </div>
        @if (!Model.RecentApplications.Any())
        {
            <div class="panel-empty">No applications yet.</div>
        }
        else
        {
            @foreach (var app in Model.RecentApplications)
            {
                <div class="panel-item">
                    <div class="panel-item-avatar">
                        @(app.CompanyName?.Length > 0 ? app.CompanyName[0].ToString().ToUpper() : "?")
                    </div>
                    <div class="panel-item-info">
                        <div class="panel-item-title">@app.OpportunityTitle</div>
                        <div class="panel-item-sub">
                            <span>@app.CompanyName</span> · <span>@app.ApplicationDate.ToString("MMM dd")</span>
                        </div>
                    </div>
                    @{
                        var badgeCls = app.Status?.ToUpper() switch
                        {
                            "ACCEPTED" or "SHORTLISTED" => "badge-green",
                            "REJECTED" => "badge-red",
                            "WITHDRAWN" => "badge-gray",
                            _ => "badge-amber"
                        };
                        var statusLabel = app.Status?.ToUpper() switch {
                            "PENDING" => "Pending", "SHORTLISTED" => "Shortlisted",
                            "ACCEPTED" => "Accepted", "REJECTED" => "Rejected",
                            "WITHDRAWN" => "Withdrawn", _ => app.Status
                        };
                    }
                    <span class="badge @badgeCls">@statusLabel</span>
                </div>
            }
        }
    </div>

    <!-- Recommended Jobs -->
    <div class="dash-panel">
        <div class="panel-header">
            <h2 class="panel-title">Recommended for You</h2>
            <a href="/JobSeeker/OpportunitiesListing" class="panel-link">BROWSE MORE</a>
        </div>
        <div class="panel-item">
            <div class="panel-item-avatar" style="background:#e0f2fe; color:#0284c7;">T</div>
            <div class="panel-item-info">
                <div class="panel-item-title">Frontend Developer</div>
                <div class="panel-item-sub"><span>TECHCORP</span> · <span>Negotiable</span></div>
            </div>
            <i class="fa-solid fa-chevron-right panel-item-arrow"></i>
        </div>
        <div class="panel-item">
            <div class="panel-item-avatar" style="background:#e0f2fe; color:#0284c7;">T</div>
            <div class="panel-item-info">
                <div class="panel-item-title">Backend Developer</div>
                <div class="panel-item-sub"><span>TECHCORP</span> · <span>Negotiable</span></div>
            </div>
            <i class="fa-solid fa-chevron-right panel-item-arrow"></i>
        </div>
        <div class="panel-item">
            <div class="panel-item-avatar" style="background:#ede9fe; color:#7c3aed;">F</div>
            <div class="panel-item-info">
                <div class="panel-item-title">Data Analyst</div>
                <div class="panel-item-sub"><span>FINANCEHUB</span> · <span>Negotiable</span></div>
            </div>
            <i class="fa-solid fa-chevron-right panel-item-arrow"></i>
        </div>
    </div>
</div>