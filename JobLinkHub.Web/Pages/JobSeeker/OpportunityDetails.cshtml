@page
@model JobLinkHub.Web.Pages.JobSeeker.OpportunityDetailsModel
@{
    ViewData["Title"] = Model.Title;
    Layout = "_DashboardLayout";
    ViewData["DashboardRole"] = "Candidate";
    ViewData["ActivePage"] = "";
}

<div style="margin-bottom:1.5rem;">
    <a href="/JobSeeker/OpportunitiesListing" class="table-action-link">
        <i class="fa-solid fa-arrow-left"></i> Back to listings
    </a>
</div>

@if (Model.NotFoundMessage != null)
{
    <div class="alert alert-danger">@Model.NotFoundMessage</div>
}
else
{
    <!-- Header card -->
    <div class="dash-form-card" style="margin-bottom:1rem;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;flex-wrap:wrap;">
            <div>
                <span class="badge badge-blue" style="margin-bottom:0.6rem;">@Model.Type</span>
                <h1 class="dash-greeting" style="font-size:1.5rem;margin-bottom:0.25rem;">@Model.Title</h1>
                <p style="color:var(--color-accent);font-weight:600;font-size:0.92rem;">
                    @Model.CompanyName
                    @if (!string.IsNullOrEmpty(Model.Location))
                    {
                        <span style="color:var(--color-text-muted)"> · @Model.Location</span>
                    }
                </p>
                @if (Model.Deadline.HasValue)
                {
                    <p style="font-size:0.82rem;color:#d97706;margin-top:0.4rem;">
                        <i class="fa-regular fa-clock"></i> Deadline: @Model.Deadline.Value.ToString("MMMM dd, yyyy")
                    </p>
                }
            </div>
            <div>
                @if (Model.AlreadyApplied)
                {
                    <span class="badge badge-green" style="padding:0.5rem 1rem;font-size:0.85rem;">
                        <i class="fa-solid fa-circle-check"></i> Already Applied
                    </span>
                }
                else
                {
                    <a href="/JobSeeker/Apply?id=@Model.Id" class="cta-btn">
                        Apply Now <i class="fa-solid fa-arrow-right"></i>
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- Description -->
    <div class="dash-form-card" style="margin-bottom:1rem;">
        <h2 class="panel-title" style="margin-bottom:0.75rem;">About this opportunity</h2>
        <p style="color:var(--color-text-light);line-height:1.7;font-size:0.92rem;">@Model.Description</p>
    </div>

    <!-- Skills -->
    @if (Model.RequiredSkills.Any())
    {
        <div class="dash-form-card" style="margin-bottom:1rem;">
            <h2 class="panel-title" style="margin-bottom:0.75rem;">Required Skills</h2>
            <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
                @foreach (var s in Model.RequiredSkills)
                {
                    <span class="badge badge-gray">@s</span>
                }
            </div>
        </div>
    }

    <!-- Employer -->
    @if (!string.IsNullOrEmpty(Model.EmployerDescription))
    {
        <div class="dash-form-card">
            <h2 class="panel-title" style="margin-bottom:0.75rem;">About @Model.CompanyName</h2>
            <p style="color:var(--color-text-light);line-height:1.7;font-size:0.92rem;">@Model.EmployerDescription</p>
        </div>
    }
}