@page
@model JobLinkHub.Web.Pages.JobSeeker.BuildProfileModel
@{
    ViewData["Title"] = "My Profile";
    Layout = "_DashboardLayout";
    ViewData["DashboardRole"] = "Candidate";
    ViewData["UserName"] = "Candidate";
    ViewData["ActivePage"] = "MyProfile";
}

<div style="margin-bottom: 1.5rem;">
    <h1 class="dash-greeting" style="font-size: 1.4rem;">My Profile</h1>
    <p class="dash-greeting-sub">Complete your profile to attract employers.</p>
</div>

@if (Model.Message != null)
{
    <div class="alert @(Model.Success ? "alert-success" : "alert-danger")">@Model.Message</div>
}

<form method="post" enctype="multipart/form-data">

    <!-- Personal Information -->
    <div class="dash-form-card" style="margin-bottom:1rem;">
        <h2 style="font-size: 1rem; font-weight: 700; margin-bottom: 1.2rem;">Personal Information</h2>
        <div class="dash-form-grid">
            <div class="form-field">
                <label asp-for="FirstName">First Name <span style="color:red;">*</span></label>
                <input asp-for="FirstName" type="text" placeholder="John" required />
            </div>
            <div class="form-field">
                <label asp-for="LastName">Last Name <span style="color:red;">*</span></label>
                <input asp-for="LastName" type="text" placeholder="Doe" required />
            </div>
        </div>
        <div class="form-field">
            <label asp-for="Bio">Bio / Summary</label>
            <textarea asp-for="Bio" rows="3" placeholder="Tell employers about yourself..."></textarea>
        </div>
        <div class="dash-form-grid">
            <div class="form-field">
                <label asp-for="Location">Location</label>
                <input asp-for="Location" type="text" placeholder="Kigali, Rwanda" />
            </div>
            <div class="form-field">
                <label asp-for="PhoneNumber">Phone</label>
                <input asp-for="PhoneNumber" type="tel" placeholder="+250 ..." />
            </div>
        </div>
        <div class="dash-form-grid">
            <div class="form-field">
                <label asp-for="CareerInterest">Career Interest / Area</label>
                <input asp-for="CareerInterest" type="text" placeholder="e.g. Software Engineering" />
            </div>
            <div class="form-field">
                <label asp-for="LinkedInUrl">LinkedIn URL</label>
                <input asp-for="LinkedInUrl" type="url" placeholder="https://linkedin.com/in/..." />
            </div>
            <div class="form-field">
                <label asp-for="PortfolioUrl">Portfolio / GitHub</label>
                <input asp-for="PortfolioUrl" type="url" placeholder="https://github.com/..." />
            </div>
            <div class="form-field" style="grid-column:1/-1;">
                <label asp-for="ResumeFile">Upload CV / Resume</label>
                @if (!string.IsNullOrEmpty(Model.ExistingResumeUrl))
                {
                    <div style="display:flex;align-items:center;gap:0.8rem;margin-bottom:0.5rem;padding:0.55rem 0.8rem;background:var(--color-bg-subtle,#f8fafc);border:1px solid var(--color-border);border-radius:8px;">
                        <i class="fa-solid fa-file-pdf" style="color:#ef4444;font-size:1.1rem;"></i>
                        <span style="font-size:0.85rem;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@Model.ExistingResumeFileName</span>
                        <a href="@Model.ExistingResumeUrl" target="_blank" class="table-action-link" style="white-space:nowrap;">View</a>
                    </div>
                    <small style="color:var(--color-text-muted);font-size:0.75rem;">Upload a new file to replace the existing one.</small>
                }
                <input asp-for="ResumeFile" type="file" accept=".pdf,.doc,.docx"
                       style="margin-top:0.4rem;display:block;width:100%;font-size:0.88rem;" />
                <small style="color:var(--color-text-muted);font-size:0.75rem;">PDF, DOC or DOCX · Max 5 MB</small>
            </div>
        </div>
    </div>

    <!-- Education -->
    <div class="dash-form-card" style="margin-bottom:1rem;">
        <h2 style="font-size: 1rem; font-weight: 700; margin-bottom: 1.2rem;">Education</h2>
        <div class="dash-form-grid">
            <div class="form-field">
                <label asp-for="EducationLevel">Education Level</label>
                <select asp-for="EducationLevel">
                    <option value="">Select level...</option>
                    <option>High School</option>
                    <option>Diploma</option>
                    <option>Bachelor's Degree</option>
                    <option>Master's Degree</option>
                    <option>PhD</option>
                    <option>Other</option>
                </select>
            </div>
            <div class="form-field">
                <label asp-for="Institution">Institution / School</label>
                <input asp-for="Institution" type="text" placeholder="University of Rwanda" />
            </div>
            <div class="form-field">
                <label asp-for="GraduationYear">Graduation Year</label>
                <input asp-for="GraduationYear" type="number" placeholder="2024" min="1990" max="2030" />
            </div>
        </div>
    </div>

    <!-- Skills -->
    @if (Model.SkillsByCategory.Any())
    {
        <div class="dash-form-card" style="margin-bottom:1rem;">
            <h2 style="font-size: 1rem; font-weight: 700; margin-bottom: 0.4rem;">Skills</h2>
            <p style="font-size:0.82rem;color:var(--color-text-muted);margin-bottom:1rem;">Select all skills that apply to you.</p>
            @foreach (var category in Model.SkillsByCategory)
            {
                <div style="margin-bottom:1rem;">
                    <p style="font-size:0.78rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:var(--color-text-muted);margin-bottom:0.5rem;">@category.Category</p>
                    <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
                        @foreach (var skill in category.Skills)
                        {
                            var isSelected = Model.SelectedSkillIds.Contains(skill.Id);
                            <label style="display:flex;align-items:center;gap:0.3rem;cursor:pointer;padding:0.3rem 0.6rem;border:1px solid @(isSelected ? "var(--color-accent)" : "var(--color-border)");border-radius:6px;font-size:0.82rem;background:@(isSelected ? "var(--color-accent-light)" : "transparent");">
                                <input type="checkbox" name="SelectedSkillIds" value="@skill.Id" @(isSelected ? "checked" : "") style="width:14px;height:14px;" />
                                @skill.Name
                            </label>
                        }
                    </div>
                </div>
            }
        </div>
    }

    <div class="dash-form-actions">
        <button type="submit" class="dash-submit-btn">Save Profile</button>
    </div>

</form>
