@page
@model JobLinkHub.Web.Pages.JobSeeker.UploadSkillEvidenceModel
@{
    ViewData["Title"] = "Skill Evidence";
    Layout = "_DashboardLayout";
    ViewData["DashboardRole"] = "Candidate";
    ViewData["ActivePage"] = "MyProfile";
}

<div style="margin-bottom:1.5rem;">
    <p class="dash-header-label">MY PROFILE</p>
    <h1 class="dash-greeting">Skill Evidence</h1>
    <p class="dash-greeting-sub">Upload certificates, portfolio links, and proof of your skills.</p>
</div>

@if (Model.Message != null)
{
    <div class="alert @(Model.Success ? "alert-success" : "alert-danger")" style="margin-bottom:1rem;">
        @Model.Message
    </div>
}

<div class="dash-panels" style="grid-template-columns:1fr 1fr;align-items:start;">

    <!-- Add Evidence Form -->
    <div class="dash-form-card">
        <h2 class="panel-title" style="margin-bottom:1rem;">Add New Evidence</h2>
        <form method="post">
            <div class="form-field">
                <label>Skill</label>
                <select asp-for="SkillId">
                    <option value="">-- Select a skill --</option>
                    @foreach (var s in Model.AvailableSkills)
                    {
                        <option value="@s.Id">@s.Name</option>
                    }
                </select>
            </div>
            <div class="form-field-row">
                <div class="form-field">
                    <label>Proficiency</label>
                    <select asp-for="ProficiencyLevel">
                        <option>Beginner</option>
                        <option>Intermediate</option>
                        <option>Advanced</option>
                        <option>Expert</option>
                    </select>
                </div>
                <div class="form-field">
                    <label>Evidence Type</label>
                    <select asp-for="EvidenceType">
                        <option>Certificate</option>
                        <option>Portfolio</option>
                        <option>Project</option>
                        <option>Course</option>
                        <option>Other</option>
                    </select>
                </div>
            </div>
            <div class="form-field">
                <label>URL / Link</label>
                <input asp-for="EvidenceUrl" type="url" placeholder="https://..." />
            </div>
            <div class="form-field">
                <label>Description</label>
                <textarea asp-for="Description" rows="2" placeholder="Brief description..."></textarea>
            </div>
            <div class="dash-form-actions">
                <a href="/JobSeeker/BuildProfile" class="dash-cancel-btn">← Back to Profile</a>
                <button type="submit" class="dash-submit-btn">
                    <i class="fa-solid fa-plus"></i> Add Evidence
                </button>
            </div>
        </form>
    </div>

    <!-- My Evidence List -->
    <div class="dash-panel">
        <div class="panel-header">
            <h2 class="panel-title">My Evidence</h2>
        </div>
        @if (!Model.MyEvidence.Any())
        {
            <div class="panel-empty">No evidence added yet.</div>
        }
        @foreach (var e in Model.MyEvidence)
        {
            <div class="panel-item">
                <div class="panel-item-avatar" style="background:var(--color-accent-light);color:var(--color-accent);">
                    <i class="fa-solid fa-certificate"></i>
                </div>
                <div class="panel-item-info">
                    <div class="panel-item-title">@e.SkillName</div>
                    <div class="panel-item-sub">
                        <span class="badge badge-blue">@e.ProficiencyLevel</span>
                        <span class="badge badge-gray">@e.EvidenceType</span>
                    </div>
                    @if (!string.IsNullOrEmpty(e.Description))
                    {
                        <div style="font-size:0.78rem;color:var(--color-text-light);margin-top:0.2rem;">@e.Description</div>
                    }
                    @if (!string.IsNullOrEmpty(e.Url))
                    {
                        <a href="@e.Url" target="_blank" class="table-action-link" style="font-size:0.78rem;">View link <i class="fa-solid fa-arrow-up-right-from-square"></i></a>
                    }
                </div>
            </div>
        }
    </div>

</div>