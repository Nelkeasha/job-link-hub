@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<section style="padding:5rem 0;background:var(--color-bg);min-height:60vh;">
    <div class="section-container" style="text-align:center;max-width:600px;">
        <div style="font-size:4rem;color:var(--color-text-muted);margin-bottom:1rem;">
            <i class="fa-solid fa-circle-exclamation"></i>
        </div>
        <h1 style="font-family:'Outfit',sans-serif;font-size:2rem;font-weight:800;margin-bottom:0.5rem;">Something went wrong</h1>
        <p style="color:var(--color-text-light);margin-bottom:1.5rem;">An error occurred while processing your request. Please try again.</p>

        @if (Model.ShowRequestId)
        {
            <div class="dash-info-bar" style="margin-bottom:1.2rem;text-align:left;">
                <strong>Request ID:</strong> <code>@Model.RequestId</code>
            </div>
        }

        <div style="display:flex;gap:0.8rem;justify-content:center;">
            <a href="/" class="cta-btn"><i class="fa-solid fa-house"></i> Go Home</a>
            <a href="javascript:history.back()" class="dash-cancel-btn">Go Back</a>
        </div>
    </div>
</section>
