@{
    var dashboardRole = ViewData["DashboardRole"]?.ToString() ?? "Candidate";
    var userName = ViewData["UserName"]?.ToString() ?? "User";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JobLink Hub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="dashboard-body">

    <!-- Sidebar -->
    <aside class="dash-sidebar" id="dashSidebar">
        <div class="sidebar-top">
            <a href="/" class="sidebar-brand">
                <span class="brand-icon">J</span>
                <span class="brand-text">Job<span class="brand-accent">Link</span> Hub</span>
            </a>
        </div>

        <p class="sidebar-section-label">MAIN MENU</p>

        <nav class="sidebar-nav">
            @if (dashboardRole == "Candidate")
            {
                <a href="/JobSeeker/Dashboard" class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "Overview" ? "active" : "")">
                    <i class="fa-solid fa-grid-2"></i><span>Overview</span>
                </a>
                <a href="/JobSeeker/MyApplications" class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "AppliedJobs" ? "active" : "")">
                    <i class="fa-solid fa-file-lines"></i><span>Applied Jobs</span>
                </a>
                <a href="/JobSeeker/SavedJobs" class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "SavedJobs" ? "active" : "")">
                    <i class="fa-regular fa-heart"></i><span>Saved Jobs</span>
                </a>
                <a href="/JobSeeker/BuildProfile" class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "MyProfile" ? "active" : "")">
                    <i class="fa-regular fa-user"></i><span>My Profile</span>
                </a>
            }
            else if (dashboardRole == "Employer")
            {
                <a href="/Employer/EmployerDashboard" class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "Overview" ? "active" : "")">
                    <i class="fa-solid fa-grid-2"></i><span>Overview</span>
                </a>
                <a href="/Employer/PostOpportunity" class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "PostJob" ? "active" : "")">
                    <i class="fa-solid fa-pen-to-square"></i><span>Post a Job</span>
                </a>
                <a href="/Employer/ManageOpportunities" class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "MyListings" ? "active" : "")">
                    <i class="fa-solid fa-briefcase"></i><span>My Listings</span>
                </a>
                <a href="/Employer/ViewApplicants" class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "Applicants" ? "active" : "")">
                    <i class="fa-solid fa-users"></i><span>Applicants</span>
                </a>
                <a href="/Employer/CompanyProfile" class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "Company" ? "active" : "")">
                    <i class="fa-solid fa-building"></i><span>Company</span>
                </a>
            }
            else if (dashboardRole == "Admin")
            {
                <a href="/Admin/AdminDashboard" class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "Overview" ? "active" : "")">
                    <i class="fa-solid fa-grid-2"></i><span>Overview</span>
                </a>
                <a href="/Admin/ManageUsers" class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "ManageUsers" ? "active" : "")">
                    <i class="fa-solid fa-users-gear"></i><span>Manage Users</span>
                </a>
                <a href="/Admin/ModerateOpportunities" class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "ModerateOpportunities" ? "active" : "")">
                    <i class="fa-solid fa-clipboard-check"></i><span>Moderate Opportunities</span>
                </a>
                <a href="/Admin/Reports" class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "Reports" ? "active" : "")">
                    <i class="fa-solid fa-chart-bar"></i><span>Reports</span>
                </a>
            }

            <a href="#" class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "Settings" ? "active" : "")">
                <i class="fa-solid fa-gear"></i><span>Settings</span>
            </a>
        </nav>

        <div class="sidebar-bottom">
            <div class="sidebar-support-card">
                <i class="fa-solid fa-headset"></i>
                <div>
                    <strong>Need Support?</strong>
                    <span>Contact our experts</span>
                </div>
            </div>
            <a href="/Auth/Logout" class="sidebar-signout">
                <i class="fa-solid fa-right-from-bracket"></i><span>Sign Out</span>
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="dash-main">
        <!-- Top Bar -->
        <header class="dash-topbar">
            <button class="sidebar-toggle" id="sidebarToggle">
                <i class="fa-solid fa-bars"></i>
            </button>
            <div class="topbar-search">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" placeholder="Search candidates, jobs, or metrics..." />
            </div>
            <div class="topbar-right">
                <button class="topbar-notification">
                    <i class="fa-regular fa-bell"></i>
                </button>
                <div class="topbar-user">
                    <div class="topbar-user-info">
                        <span class="topbar-user-name">@userName</span>
                        <span class="topbar-user-role role-@dashboardRole.ToLower()">@dashboardRole.ToUpper()</span>
                    </div>
                    <div class="topbar-avatar">
                        <i class="fa-regular fa-user"></i>
                    </div>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <main class="dash-content">
            @if (TempData["SuccessMessage"] is string successMsg)
            {
                <div class="alert alert-success" style="margin-bottom:1rem;">
                    <i class="fa-solid fa-circle-check"></i> @successMsg
                </div>
            }
            @if (TempData["ErrorMessage"] is string errorMsg)
            {
                <div class="alert alert-danger" style="margin-bottom:1rem;">
                    <i class="fa-solid fa-circle-xmark"></i> @errorMsg
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <script>
        document.getElementById('sidebarToggle')?.addEventListener('click', function() {
            document.getElementById('dashSidebar').classList.toggle('open');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
