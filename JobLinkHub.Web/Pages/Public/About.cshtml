@page
@model JobLinkHub.Web.Pages.AboutModel
@{
    ViewData["Title"] = "About JobLink Hub";
}

<section style="padding:4rem 0 2rem;background:var(--color-bg);">
    <div class="section-container">
        <div style="text-align:center;max-width:680px;margin:0 auto 3rem;">
            <span class="badge badge-blue" style="margin-bottom:1rem;">About JobLink Hub</span>
            <h1 class="hero-title">A smarter way to connect talent to opportunity</h1>
            <p class="hero-sub">
                JobLink Hub is a skill-first career opportunity platform designed to help students,
                graduates, and emerging professionals connect with meaningful opportunities while
                helping employers discover capable talent beyond the traditional CV.
            </p>
        </div>
    </div>
</section>

<section class="features-section">
    <div class="section-container">
        <div class="section-title-row">
            <h2 class="section-title">Our Purpose</h2>
        </div>
        <p style="color:var(--color-text-light);max-width:760px;margin:0 auto 2.5rem;text-align:center;line-height:1.7;">
            Many talented young people struggle to access meaningful opportunities because
            recruitment systems often depend heavily on work experience, academic credentials,
            and CV-based screening. JobLink Hub was created to bridge this gap by giving
            users a platform where they can present their skills, potential, and readiness
            more effectively.
        </p>

        <div class="section-title-row" style="margin-top:2.5rem;">
            <h2 class="section-title">What Makes JobLink Hub Different</h2>
        </div>
        <div class="features-grid" style="margin-top:1.5rem;">
            <div class="feature-card">
                <div class="category-icon"><i class="fa-solid fa-star"></i></div>
                <h3>Skill-first profiles</h3>
                <p>Users can showcase their practical strengths, qualifications, and readiness beyond static CV information.</p>
            </div>
            <div class="feature-card">
                <div class="category-icon"><i class="fa-solid fa-road"></i></div>
                <h3>Multiple opportunity pathways</h3>
                <p>The platform supports jobs, internships, gigs, mentorships, and training opportunities in one place.</p>
            </div>
            <div class="feature-card">
                <div class="category-icon"><i class="fa-solid fa-building"></i></div>
                <h3>Employer-friendly review flow</h3>
                <p>Employers can manage opportunities, review applicants, and make informed decisions through a structured hiring workspace.</p>
            </div>
            <div class="feature-card">
                <div class="category-icon"><i class="fa-solid fa-chart-line"></i></div>
                <h3>Career growth orientation</h3>
                <p>JobLink Hub is designed to support the transition from learning to work by making opportunities more visible and accessible.</p>
            </div>
        </div>
    </div>
</section>

<section style="padding:3rem 0;background:var(--color-surface);">
    <div class="section-container">
        <div class="section-title-row">
            <h2 class="section-title">Who the Platform Serves</h2>
        </div>
        <div class="features-grid" style="margin-top:1.5rem;">
            <div class="feature-card">
                <div class="category-icon"><i class="fa-solid fa-user-graduate"></i></div>
                <h3>Students &amp; Graduates</h3>
                <p>Find internships, entry-level jobs, training opportunities, and early-career pathways.</p>
            </div>
            <div class="feature-card">
                <div class="category-icon"><i class="fa-solid fa-briefcase"></i></div>
                <h3>Emerging Professionals</h3>
                <p>Showcase practical skills, build visibility, and access opportunities that match career goals.</p>
            </div>
            <div class="feature-card">
                <div class="category-icon"><i class="fa-solid fa-handshake"></i></div>
                <h3>Employers</h3>
                <p>Discover talent, post opportunities, and review candidates using a more structured and skill-aware process.</p>
            </div>
        </div>
    </div>
</section>

<section style="padding:3rem 0 4rem;background:var(--color-bg);">
    <div class="section-container">
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem;margin-bottom:2.5rem;">
            <div class="feature-card" style="border-left:3px solid var(--color-primary);">
                <h3 style="color:var(--color-primary);margin-bottom:0.5rem;">Our Mission</h3>
                <p>To bridge the gap between talent and opportunity by creating a platform that values skills, potential, and career readiness.</p>
            </div>
            <div class="feature-card" style="border-left:3px solid var(--color-primary);">
                <h3 style="color:var(--color-primary);margin-bottom:0.5rem;">Core Value</h3>
                <p>We believe opportunity should not be limited by lack of experience when skill, promise, and effort are clearly present.</p>
            </div>
        </div>
        <div style="text-align:center;">
            <h3 style="font-family:'Outfit',sans-serif;font-size:1.3rem;font-weight:700;margin-bottom:1.2rem;">Ready to get started?</h3>
            <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
                <a asp-page="/Auth/ChooseRole" class="cta-btn"><i class="fa-solid fa-user-plus"></i> Create Account</a>
                <a asp-page="/Auth/Login" class="dash-cancel-btn">Log In</a>
            </div>
        </div>
    </div>
</section>