@page
@model JobLinkHub.Web.Pages.Public.ContactModel
@{
    ViewData["Title"] = "Contact Us";
    Layout = "_Layout";
}

<section style="padding:4rem 0;background:var(--color-bg);">
  <div class="section-container" style="max-width:760px;">

    <div class="section-title-row text-center">
      <p class="section-subtitle"><i class="fa-solid fa-envelope"></i> CONTACT US</p>
      <h1 class="section-heading">Get in <em>Touch</em></h1>
      <p class="section-desc" style="margin:0 auto;">Have a question or feedback? We'd love to hear from you.</p>
    </div>

    @if (Model.Submitted)
    {
      <div class="alert alert-success" style="text-align:center;padding:2rem;">
        <i class="fa-solid fa-circle-check" style="font-size:2rem;display:block;margin-bottom:0.5rem;"></i>
        <strong>Message sent!</strong><br/>
        Thanks for reaching out. We'll get back to you within 1–2 business days.
      </div>
    }
    else
    {
      <div class="dash-form-card" style="margin-bottom:2rem;">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
          <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        <form method="post">
          @Html.AntiForgeryToken()
          <div class="form-field-row">
            <div class="form-field">
              <label>Name *</label>
              <input name="Name" value="@Model.Name" type="text" placeholder="Your name" required />
            </div>
            <div class="form-field">
              <label>Email *</label>
              <input name="Email" value="@Model.Email" type="email" placeholder="you@example.com" required />
            </div>
          </div>
          <div class="form-field">
            <label>Subject</label>
            <input name="Subject" value="@Model.Subject" type="text" placeholder="What is this about?" />
          </div>
          <div class="form-field">
            <label>Message *</label>
            <textarea name="Message" rows="5" placeholder="Tell us how we can help..." required>@Model.Message</textarea>
          </div>
          <button type="submit" class="form-submit-btn">
            <i class="fa-solid fa-paper-plane"></i> Send Message
          </button>
        </form>
      </div>

      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;">
        <div class="feature-card" style="text-align:center;">
          <div class="category-icon cat-blue" style="margin:0 auto 0.6rem;"><i class="fa-solid fa-envelope"></i></div>
          <p style="font-weight:600;font-size:0.9rem;margin-bottom:0.2rem;">Email</p>
          <p style="font-size:0.82rem;color:var(--color-text-light);">support@joblinkhub.com</p>
        </div>
        <div class="feature-card" style="text-align:center;">
          <div class="category-icon cat-green" style="margin:0 auto 0.6rem;"><i class="fa-solid fa-location-dot"></i></div>
          <p style="font-weight:600;font-size:0.9rem;margin-bottom:0.2rem;">Location</p>
          <p style="font-size:0.82rem;color:var(--color-text-light);">Kigali, Rwanda</p>
        </div>
        <div class="feature-card" style="text-align:center;">
          <div class="category-icon cat-amber" style="margin:0 auto 0.6rem;"><i class="fa-solid fa-clock"></i></div>
          <p style="font-weight:600;font-size:0.9rem;margin-bottom:0.2rem;">Response Time</p>
          <p style="font-size:0.82rem;color:var(--color-text-light);">Within 1–2 business days</p>
        </div>
      </div>
    }

  </div>
</section>
