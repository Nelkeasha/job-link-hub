@page
@model JobLinkHub.Web.Pages.Public.OpportunitiesModel
@{
    ViewData["Title"] = "Opportunities";
}

<section class="opportunities-page">
    <div class="container opportunities-wrapper">

        <div class="opportunities-hero">
            <span class="opportunities-eyebrow">Explore opportunities</span>
            <h1>Find opportunities that match your goals</h1>
            <p>
                Browse jobs, internships, training opportunities, gigs, and mentorships designed to support growth and career development.
            </p>
        </div>

        <form method="get" class="opportunities-filter-bar">
            <div class="filter-input-group">
                <label for="SearchQ">Search</label>
                <input asp-for="SearchQ" type="text" placeholder="Search by title, skill, or keyword" />
            </div>

            <div class="filter-input-group">
                <label for="FilterType">Type</label>
                <select asp-for="FilterType">
                    <option value="">All Types</option>
                    <option>Job</option>
                    <option>Internship</option>
                    <option>Training</option>
                    <option>Gig</option>
                    <option>Mentorship</option>
                </select>
            </div>

            <div class="filter-input-group">
                <label for="FilterLocation">Location</label>
                <select asp-for="FilterLocation">
                    <option value="">All Locations</option>
                    <option>Kigali</option>
                    <option>Remote</option>
                    <option>Hybrid</option>
                </select>
            </div>

            <div class="filter-input-group" style="align-self: flex-end;">
                <button type="submit" class="public-opportunity-btn">Search</button>
            </div>
        </form>

        <div class="opportunities-results-top">
            <div>
                <h2>Available Opportunities</h2>
                <p>@Model.Opportunities.Count opportunities currently listed</p>
            </div>
        </div>

        <div class="opportunity-card-grid">
            @foreach (var item in Model.Opportunities)
            {
                <div class="public-opportunity-card">
                    <div class="public-opportunity-top">
                        <span class="public-opportunity-type">@item.OpportunityType</span>
                        <span class="public-opportunity-status">@item.Status</span>
                    </div>

                    <h3>@item.Title</h3>
                    <p class="public-opportunity-company">@item.CompanyName</p>
                    <p class="public-opportunity-description">@(item.Description.Length > 150 ? item.Description.Substring(0, 150) + "..." : item.Description)</p>

                    <div class="public-opportunity-meta">
                        <span>@item.Location</span>
                        @if (item.Deadline.HasValue)
                        {
                            <span>Deadline: @item.Deadline.Value.ToString("dd MMM yyyy")</span>
                        }
                    </div>

                    <div class="public-opportunity-skills">
                        @foreach (var skill in item.RequiredSkills)
                        {
                            <span>@skill</span>
                        }
                    </div>

                    <div class="public-opportunity-actions">
                        <button type="button"
                                class="public-opportunity-btn view-details-btn"
                                data-title="@item.Title"
                                data-company="@item.CompanyName"
                                data-type="@item.OpportunityType"
                                data-status="@item.Status"
                                data-location="@item.Location"
                                data-deadline="@(item.Deadline.HasValue ? item.Deadline.Value.ToString("dd MMM yyyy") : "")"
                                data-qualification="@item.QualificationRequired"
                                data-description="@item.Description">
                            View Details
                        </button>
                    </div>
                </div>
            }
        </div>

    </div>
</section>

<div id="opportunityModal" class="opportunity-modal">
    <div class="opportunity-modal-content">
        <button type="button" id="closeOpportunityModal" class="opportunity-modal-close">&times;</button>

        <div class="opportunity-modal-top">
            <span id="modalType" class="public-opportunity-type"></span>
            <span id="modalStatus" class="public-opportunity-status"></span>
        </div>

        <h2 id="modalTitle"></h2>
        <p id="modalCompany" class="modal-company"></p>

        <div class="modal-meta-grid">
            <div>
                <span>Location</span>
                <strong id="modalLocation"></strong>
            </div>
            <div>
                <span>Deadline</span>
                <strong id="modalDeadline"></strong>
            </div>
            <div>
                <span>Qualification</span>
                <strong id="modalQualification"></strong>
            </div>
        </div>

        <div class="modal-section">
            <h3>Opportunity Description</h3>
            <p id="modalDescription"></p>
        </div>

        <div class="modal-actions">
            <a asp-page="/Auth/Login" class="public-opportunity-btn">Log in to Apply</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const modal = document.getElementById("opportunityModal");
            const closeBtn = document.getElementById("closeOpportunityModal");
            const detailButtons = document.querySelectorAll(".view-details-btn");

            const modalTitle = document.getElementById("modalTitle");
            const modalCompany = document.getElementById("modalCompany");
            const modalType = document.getElementById("modalType");
            const modalStatus = document.getElementById("modalStatus");
            const modalLocation = document.getElementById("modalLocation");
            const modalDeadline = document.getElementById("modalDeadline");
            const modalQualification = document.getElementById("modalQualification");
            const modalDescription = document.getElementById("modalDescription");

            detailButtons.forEach(button => {
                button.addEventListener("click", function () {
                    modalTitle.textContent = this.dataset.title || "";
                    modalCompany.textContent = this.dataset.company || "";
                    modalType.textContent = this.dataset.type || "";
                    modalStatus.textContent = this.dataset.status || "";
                    modalLocation.textContent = this.dataset.location || "";
                    modalDeadline.textContent = this.dataset.deadline || "";
                    modalQualification.textContent = this.dataset.qualification || "";
                    modalDescription.textContent = this.dataset.description || "";

                    modal.classList.add("show");
                });
            });

            closeBtn.addEventListener("click", function () {
                modal.classList.remove("show");
            });

            modal.addEventListener("click", function (e) {
                if (e.target === modal) {
                    modal.classList.remove("show");
                }
            });
        });
    </script>
}