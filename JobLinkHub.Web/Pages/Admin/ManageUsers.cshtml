@page
@model JobLinkHub.Web.Pages.Admin.ManageUsersModel
@{
    ViewData["Title"] = "Manage Users";
    Layout = "_DashboardLayout";
    ViewData["DashboardRole"] = "Admin";
    ViewData["UserName"] = "Admin";
    ViewData["ActivePage"] = "ManageUsers";
}

<div style="margin-bottom: 1.5rem;">
    <h1 class="dash-greeting" style="font-size: 1.4rem;">Manage Users</h1>
    <p class="dash-greeting-sub">View and manage all registered users.</p>
</div>

@if (Model.Message != null)
{
    <div class="alert @(Model.Message.StartsWith("Error") ? "alert-danger" : "alert-success")">@Model.Message</div>
}

<form method="get" class="dash-filter-bar">
    <div class="filter-group">
        <label>Search</label>
        <input asp-for="SearchQ" type="text" placeholder="Name or email..." />
    </div>
    <div class="filter-group">
        <label>Role</label>
        <select asp-for="FilterRole">
            <option value="">All Roles</option>
            <option value="CANDIDATE">Job Seeker</option>
            <option value="EMPLOYER">Employer</option>
            <option value="ADMIN">Admin</option>
        </select>
    </div>
    <button type="submit" class="filter-btn">Search</button>
</form>

<div class="dash-table-card">
    <table class="dash-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Joined</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Users.Any())
            {
                <tr><td colspan="6" class="panel-empty">No users found.</td></tr>
            }
            @foreach (var u in Model.Users)
            {
                var roleBadge = u.Role == "ADMIN" ? "badge-amber" : u.Role == "EMPLOYER" ? "badge-purple" : "badge-blue";
                var roleLabel = u.Role == "ADMIN" ? "Admin" : u.Role == "EMPLOYER" ? "Employer" : "Job Seeker";
                <tr>
                    <td><strong>@(u.FirstName + " " + u.LastName)</strong></td>
                    <td style="color: var(--color-text-light);">@u.Email</td>
                    <td><span class="badge @roleBadge">@roleLabel</span></td>
                    <td style="color: var(--color-text-light); font-size: 0.82rem;">@u.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td>
                        <span class="badge @(u.IsActive ? "badge-green" : "badge-gray")">
                            @(u.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td>
                        <div style="display:flex;gap:0.8rem;align-items:center;flex-wrap:wrap;">
                            <form method="post" asp-page-handler="ToggleStatus" style="margin:0;">
                                <input type="hidden" name="userId" value="@u.Id" />
                                <input type="hidden" name="isActive" value="@u.IsActive.ToString().ToLower()" />
                                <button type="submit" class="table-action-link" style="background:none;border:none;cursor:pointer;font-family:inherit;font-size:0.82rem;font-weight:600;padding:0;">
                                    @(u.IsActive ? "Deactivate" : "Activate")
                                </button>
                            </form>
                            @if (u.Role != "ADMIN")
                            {
                                <form method="post" asp-page-handler="Delete" style="margin:0;"
                                      onsubmit="return confirm('Permanently delete @(u.FirstName) @(u.LastName)? This cannot be undone.');">
                                    <input type="hidden" name="userId" value="@u.Id" />
                                    <button type="submit" class="table-action-link table-action-danger" style="background:none;border:none;cursor:pointer;font-family:inherit;font-size:0.82rem;font-weight:600;padding:0;">
                                        Delete
                                    </button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
