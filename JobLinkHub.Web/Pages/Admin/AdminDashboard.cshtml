@page
@model JobLinkHub.Web.Pages.Admin.AdminDashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_DashboardLayout";
    ViewData["DashboardRole"] = "Admin";
    ViewData["UserName"] = "Admin";
    ViewData["ActivePage"] = "Overview";
}

<div style="margin-bottom: 1.5rem;">
    <p class="dash-header-label">ADMIN PANEL</p>
    <h1 class="dash-greeting">Admin Dashboard</h1>
    <p class="dash-greeting-sub">Platform overview and management tools.</p>
</div>

<div class="dash-stats-row">
    @{
        var stats = new[] {
            ("Total Users", Model.TotalUsers.ToString(), "fa-solid fa-users", "stat-icon-blue"),
            ("Job Seekers", Model.TotalJobSeekers.ToString(), "fa-solid fa-user", "stat-icon-teal"),
            ("Employers", Model.TotalEmployers.ToString(), "fa-solid fa-building", "stat-icon-purple"),
            ("Active Opportunities", Model.TotalOpportunities.ToString(), "fa-solid fa-briefcase", "stat-icon-green"),
            ("Total Applications", Model.TotalApplications.ToString(), "fa-solid fa-file-lines", "stat-icon-amber"),
            ("New This Month", Model.NewUsersThisMonth.ToString(), "fa-solid fa-chart-line", "stat-icon-red"),
        };
    }
    @foreach (var (label, value, icon, colorCls) in stats)
    {
        <div class="dash-stat-card">
            <div class="stat-icon @colorCls"><i class="@icon"></i></div>
            <div class="stat-info">
                <p class="stat-label">@label</p>
                <p class="stat-value">@value</p>
            </div>
        </div>
    }
</div>

<div class="dash-panels">
    <a href="/Admin/ManageUsers" class="dash-panel" style="cursor: pointer;">
        <div style="display: flex; align-items: center; gap: 1rem;">
            <div class="stat-icon stat-icon-blue" style="width: 56px; height: 56px; font-size: 1.3rem;">
                <i class="fa-solid fa-users-gear"></i>
            </div>
            <div>
                <h3 class="panel-title">Manage Users</h3>
                <p style="color: var(--color-text-light); font-size: 0.88rem; margin: 0;">View and manage all registered users</p>
            </div>
        </div>
    </a>
    <a href="/Admin/ModerateOpportunities" class="dash-panel" style="cursor: pointer;">
        <div style="display: flex; align-items: center; gap: 1rem;">
            <div class="stat-icon stat-icon-amber" style="width: 56px; height: 56px; font-size: 1.3rem;">
                <i class="fa-solid fa-clipboard-check"></i>
            </div>
            <div>
                <h3 class="panel-title">Moderate Opportunities</h3>
                <p style="color: var(--color-text-light); font-size: 0.88rem; margin: 0;">Review and remove job postings</p>
            </div>
        </div>
    </a>
</div>