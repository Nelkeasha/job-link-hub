@page
@model JobLinkHub.Web.Pages.Admin.ModerateOpportunitiesModel
@{
    ViewData["Title"] = "Moderate Opportunities";
    Layout = "_DashboardLayout";
    ViewData["DashboardRole"] = "Admin";
    ViewData["UserName"] = "Admin";
    ViewData["ActivePage"] = "ModerateOpportunities";
}

<div style="margin-bottom: 1.5rem;">
    <h1 class="dash-greeting" style="font-size: 1.4rem;">Moderate Opportunities</h1>
    <p class="dash-greeting-sub">Review and manage all job postings.</p>
</div>

@if (Model.Message != null)
{
    <div class="alert @(Model.Message.StartsWith("Error") ? "alert-danger" : "alert-success")">@Model.Message</div>
}

<form method="get" class="dash-filter-bar">
    <div class="filter-group">
        <label>Search</label>
        <input asp-for="SearchQ" type="text" placeholder="Title or employer..." />
    </div>
    <div class="filter-group">
        <label>Type</label>
        <select asp-for="FilterType">
            <option value="">All Types</option>
            <option>Job</option>
            <option>Internship</option>
            <option>Freelance</option>
            <option>Mentorship</option>
        </select>
    </div>
    <button type="submit" class="filter-btn">Filter</button>
</form>

<div class="dash-table-card">
    <table class="dash-table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Employer</th>
                <th>Type</th>
                <th>Status</th>
                <th>Posted</th>
                <th>Apps</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Opportunities.Any())
            {
                <tr><td colspan="7" class="panel-empty">No opportunities found.</td></tr>
            }
            @foreach (var o in Model.Opportunities)
            {
                var statusBadge = o.Status == "Active" ? "badge-green" : o.Status == "Closed" ? "badge-red" : "badge-gray";
                <tr>
                    <td><strong>@o.Title</strong></td>
                    <td style="color: var(--color-text-light); font-size: 0.82rem;">@o.CompanyName</td>
                    <td><span class="badge badge-blue">@o.OpportunityType</span></td>
                    <td><span class="badge @statusBadge">@o.Status</span></td>
                    <td style="color: var(--color-text-light); font-size: 0.82rem;">@o.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td><strong>@o.ApplicationCount</strong></td>
                    <td>
                        <div style="display: flex; gap: 0.8rem; align-items: center;flex-wrap:wrap;">
                            <a href="/JobSeeker/OpportunityDetails?id=@o.Id" class="table-action-link">View</a>
                            <form method="post" asp-page-handler="ToggleStatus" style="margin:0;">
                                <input type="hidden" name="id" value="@o.Id" />
                                <input type="hidden" name="currentStatus" value="@o.Status" />
                                <button type="submit" class="table-action-link" style="background:none;border:none;cursor:pointer;font-family:inherit;font-size:0.82rem;font-weight:600;padding:0;color:@(o.Status == "Active" ? "#f59e0b" : "#16a34a");">
                                    @(o.Status == "Active" ? "Suspend" : "Activate")
                                </button>
                            </form>
                            <form method="post" asp-page-handler="Delete"
                                  onsubmit="return confirm('Delete this opportunity and all its applications?');"
                                  style="margin:0;">
                                <input type="hidden" name="id" value="@o.Id" />
                                <button type="submit" class="table-action-link table-action-danger" style="background:none;border:none;cursor:pointer;font-family:inherit;font-size:0.82rem;font-weight:600;padding:0;">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>