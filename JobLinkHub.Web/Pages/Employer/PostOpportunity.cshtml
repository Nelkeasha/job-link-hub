@page
@model JobLinkHub.Web.Pages.Employer.PostOpportunityModel
@{
    ViewData["Title"] = "Post Opportunity";
    Layout = "_DashboardLayout";
    ViewData["DashboardRole"] = "Employer";
    ViewData["UserName"] = "Employer";
    ViewData["ActivePage"] = "PostJob";
}

<div style="margin-bottom: 1.5rem;">
    <h1 class="dash-greeting" style="font-size: 1.4rem;">Post a New Job</h1>
    <p class="dash-greeting-sub">Create a clear and compelling opportunity to attract the right candidates.</p>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert @(Model.Success ? "alert-success" : "alert-danger")">@Model.Message</div>
}

<div class="dash-form-card">
    <form method="post">
        <div class="dash-form-grid">
            <div class="form-field">
                <label asp-for="Title">Opportunity Title *</label>
                <input asp-for="Title" type="text" placeholder="e.g. Frontend Developer Intern" required />
                <span asp-validation-for="Title" style="color:#ef4444;font-size:0.8rem;margin-top:0.25rem;display:block;"></span>
            </div>
            <div class="form-field">
                <label asp-for="OpportunityType">Opportunity Type</label>
                <select asp-for="OpportunityType">
                    <option value="Job">Job</option>
                    <option value="Internship">Internship</option>
                    <option value="Training">Training</option>
                    <option value="Gig">Gig</option>
                    <option value="Mentorship">Mentorship</option>
                </select>
            </div>
            <div class="form-field">
                <label asp-for="Location">Location</label>
                <input asp-for="Location" type="text" placeholder="e.g. Kigali, Remote, Hybrid" />
            </div>
            <div class="form-field">
                <label asp-for="Deadline">Application Deadline</label>
                <input asp-for="Deadline" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="Deadline" style="color:#ef4444;font-size:0.8rem;margin-top:0.25rem;display:block;"></span>
            </div>
            <div class="form-field">
                <label asp-for="QualificationRequired">Qualification Required</label>
                <input asp-for="QualificationRequired" type="text" placeholder="e.g. Diploma, Degree, Open to students" />
            </div>
            <div class="form-field">
                <label asp-for="Status">Status</label>
                <select asp-for="Status">
                    <option value="Active">Live</option>
                    <option value="Draft">Draft</option>
                </select>
            </div>
        </div>
        <div class="form-field" style="margin-top: 0.5rem;">
            <label asp-for="Description">Opportunity Description *</label>
            <textarea asp-for="Description" rows="6" placeholder="Write a detailed description of the opportunity, expectations, and responsibilities." required></textarea>
            <span asp-validation-for="Description" style="color:#ef4444;font-size:0.8rem;margin-top:0.25rem;display:block;"></span>
        </div>
        <div class="dash-form-actions">
            <a href="/Employer/ManageOpportunities" class="dash-cancel-btn">Cancel</a>
            <button type="submit" class="dash-submit-btn">Publish Opportunity</button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}