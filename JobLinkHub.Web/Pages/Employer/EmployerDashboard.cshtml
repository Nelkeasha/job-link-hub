@page
@model JobLinkHub.Web.Pages.Employer.EmployerDashboardModel
@{
    ViewData["Title"] = "Employer Dashboard";
    Layout = "_DashboardLayout";
    ViewData["DashboardRole"] = "Employer";
    ViewData["UserName"] = Model.CompanyName;
    ViewData["ActivePage"] = "Overview";
}

<!-- Header -->
<div style="margin-bottom: 1rem;">
    <h1 class="dash-greeting">Employer Dashboard</h1>
    <p class="dash-greeting-sub">Manage your job listings and track applicants.</p>
</div>

<div class="dash-info-bar">
    <i class="fa-solid fa-building"></i> Company: <strong>@Model.CompanyName</strong> | Location:
</div>

<!-- Stats -->
<div class="dash-stats-row">
    <div class="dash-stat-card">
        <div class="stat-icon stat-icon-blue"><i class="fa-solid fa-briefcase"></i></div>
        <div class="stat-info">
            <p class="stat-label">Active Jobs</p>
            <p class="stat-value">@Model.ActiveOpportunitiesCount</p>
        </div>
    </div>
    <div class="dash-stat-card">
        <div class="stat-icon stat-icon-purple"><i class="fa-solid fa-users"></i></div>
        <div class="stat-info">
            <p class="stat-label">Total Applicants</p>
            <p class="stat-value">@Model.TotalApplicantsCount</p>
        </div>
    </div>
    <div class="dash-stat-card">
        <div class="stat-icon stat-icon-red"><i class="fa-solid fa-eye"></i></div>
        <div class="stat-info">
            <p class="stat-label">Job Views</p>
            <p class="stat-value">@Model.ApplicationsReceivedCount</p>
        </div>
    </div>
    <div class="dash-stat-card">
        <div class="stat-icon stat-icon-green"><i class="fa-solid fa-clipboard-check"></i></div>
        <div class="stat-info">
            <p class="stat-label">Shortlisted</p>
            <p class="stat-value">@Model.ShortlistedCandidatesCount</p>
        </div>
    </div>
</div>

<!-- CTA -->
<div class="dash-cta-card">
    <div class="cta-icon"><i class="fa-solid fa-briefcase"></i></div>
    <h3>Need to hire someone?</h3>
    <p>Post a new job opening and reach thousands of talented candidates instantly.</p>
    <a href="/Employer/PostOpportunity" class="cta-btn">
        <i class="fa-solid fa-file-circle-plus"></i> POST A JOB
    </a>
</div>

<!-- Panels -->
<div class="dash-panels">
    <!-- Recent Applicants -->
    <div class="dash-panel">
        <div class="panel-header">
            <h2 class="panel-title">Recent Applicants</h2>
            <a href="/Employer/ViewApplicants" class="panel-link">VIEW ALL</a>
        </div>
        @if (!Model.RecentApplicants.Any())
        {
            <div class="panel-empty">No applicants yet.</div>
        }
        else
        {
            @foreach (var applicant in Model.RecentApplicants)
            {
                var initials = string.Concat(applicant.CandidateName.Split(' ').Where(w => w.Length > 0).Select(w => w[0])).ToUpper();
                <div class="panel-item">
                    <div class="panel-item-avatar">@initials</div>
                    <div class="panel-item-info">
                        <div class="panel-item-title">@applicant.CandidateName</div>
                        <div class="panel-item-sub"><span>@applicant.OpportunityTitle</span></div>
                    </div>
                    <a href="/Employer/CandidateProfileReview/@applicant.Id" class="table-action-link">Review</a>
                </div>
            }
        }
    </div>

    <!-- Quick Actions -->
    <div class="dash-panel">
        <div class="panel-header">
            <h2 class="panel-title">Quick Actions</h2>
        </div>
        <div class="quick-actions-grid">
            <a href="/Employer/ManageOpportunities" class="quick-action-link">
                <i class="fa-solid fa-briefcase"></i> Manage Jobs
            </a>
            <a href="/Employer/ViewApplicants" class="quick-action-link">
                <i class="fa-solid fa-users"></i> View Applications
            </a>
            <a href="/Employer/CompanyProfile" class="quick-action-link">
                <i class="fa-solid fa-building"></i> Company Profile
            </a>
            <a href="/Employer/PostOpportunity" class="quick-action-link">
                <i class="fa-solid fa-circle-plus"></i> Post New Job
            </a>
        </div>
    </div>
</div>