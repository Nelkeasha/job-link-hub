@page
@model JobLinkHub.Web.Pages.Employer.CompanyProfileModel
@{
    ViewData["Title"] = "Company Profile";
    Layout = "_DashboardLayout";
    ViewData["DashboardRole"] = "Employer";
    ViewData["UserName"] = "Employer";
    ViewData["ActivePage"] = "Company";
}

<div style="margin-bottom: 1.5rem;">
    <h1 class="dash-greeting" style="font-size: 1.4rem;">Company Profile</h1>
    <p class="dash-greeting-sub">Manage your company information so applicants can understand your organization better.</p>
</div>

<div style="display: grid; grid-template-columns: 1.4fr 0.6fr; gap: 1.2rem;">
    <div class="dash-form-card">
        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
            <div class="panel-item-avatar" style="width: 56px; height: 56px; font-size: 1.1rem; background: #fef3c7; color: #d97706;">
                @(string.Concat(Model.CompanyName.Split(' ').Where(w => w.Length > 0).Select(w => w[0])).ToUpper())
            </div>
            <div>
                <h2 style="font-size: 1.15rem; font-weight: 700; margin-bottom: 0.15rem;">@Model.CompanyName</h2>
                <p style="color: var(--color-text-light); font-size: 0.88rem;">@Model.Industry</p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div style="padding:0.7rem 1rem;border-radius:8px;margin-bottom:1rem;font-size:0.88rem;@(Model.Success ? "background:#f0fdf4;color:#166534;border:1px solid #bbf7d0;" : "background:#fef2f2;color:#991b1b;border:1px solid #fecaca;")">
                @Model.Message
            </div>
        }

        <form method="post">
            <div class="dash-form-grid">
                <div class="form-field"><label>First Name</label><input asp-for="FirstName" type="text" /></div>
                <div class="form-field"><label>Last Name</label><input asp-for="LastName" type="text" /></div>
                <div class="form-field"><label>Company Name</label><input asp-for="CompanyName" type="text" /></div>
                <div class="form-field"><label>Company Type</label><input asp-for="CompanyType" type="text" /></div>
                <div class="form-field"><label>Industry</label><input asp-for="Industry" type="text" /></div>
                <div class="form-field"><label>Location</label><input asp-for="Location" type="text" /></div>
                <div class="form-field"><label>Website</label><input asp-for="Website" type="text" /></div>
                <div class="form-field"><label>Phone Number</label><input asp-for="PhoneNumber" type="text" /></div>
            </div>
            <div class="form-field" style="margin-top: 0.5rem;">
                <label>Company Description</label>
                <textarea asp-for="CompanyDescription" rows="5"></textarea>
            </div>
            <div class="dash-form-actions">
                <button type="submit" class="dash-submit-btn">Save Changes</button>
            </div>
        </form>
    </div>

    <div>
        <div class="dash-panel" style="margin-bottom: 1rem;">
            <h3 class="panel-title" style="margin-bottom: 0.8rem;">Profile Preview</h3>
            <h4 style="font-weight: 700; font-size: 1rem; margin-bottom: 0.2rem;">@Model.CompanyName</h4>
            <p style="color: var(--color-text-light); font-size: 0.85rem; margin-bottom: 0.5rem;">@Model.CompanyType · @Model.Industry</p>
            <p style="color: var(--color-text-muted); font-size: 0.82rem; margin-bottom: 1rem;">@Model.Location</p>
            <div style="border-top: 1px solid var(--color-border); padding-top: 0.8rem;">
                <p class="stat-label">Website</p>
                <p style="font-size: 0.88rem; font-weight: 600; margin-bottom: 0.6rem;">@Model.Website</p>
                <p class="stat-label">Contact</p>
                <p style="font-size: 0.88rem; font-weight: 600;">@Model.ContactEmail</p>
            </div>
        </div>
        <div class="dash-panel">
            <h3 class="panel-title" style="margin-bottom: 0.6rem;">Tips</h3>
            <ul style="padding-left: 1rem; color: var(--color-text-light); font-size: 0.85rem; line-height: 1.8;">
                <li>Keep your company description clear and concise.</li>
                <li>Use a professional email and website.</li>
                <li>Make sure your location and industry are accurate.</li>
            </ul>
        </div>
    </div>
</div>