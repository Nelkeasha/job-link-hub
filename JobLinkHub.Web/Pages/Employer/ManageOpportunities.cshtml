@page
@model JobLinkHub.Web.Pages.Employer.ManageOpportunitiesModel
@{
    ViewData["Title"] = "My Listings";
    Layout = "_DashboardLayout";
    ViewData["DashboardRole"] = "Employer";
    ViewData["UserName"] = "Employer";
    ViewData["ActivePage"] = "MyListings";
}

<div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.5rem;">
    <div>
        <h1 class="dash-greeting" style="font-size: 1.4rem;">My Listings</h1>
        <p class="dash-greeting-sub">Track status, deadline, and candidate activity for each opportunity.</p>
    </div>
    <a href="/Employer/PostOpportunity" class="cta-btn"><i class="fa-solid fa-plus"></i> Post New</a>
</div>

<div class="dash-stats-row">
    <div class="dash-stat-card">
        <div class="stat-icon stat-icon-blue"><i class="fa-solid fa-list"></i></div>
        <div class="stat-info"><p class="stat-label">Total</p><p class="stat-value">@Model.TotalOpportunitiesCount</p></div>
    </div>
    <div class="dash-stat-card">
        <div class="stat-icon stat-icon-green"><i class="fa-solid fa-circle-check"></i></div>
        <div class="stat-info"><p class="stat-label">Live</p><p class="stat-value">@Model.LiveOpportunitiesCount</p></div>
    </div>
    <div class="dash-stat-card">
        <div class="stat-icon stat-icon-amber"><i class="fa-solid fa-file-pen"></i></div>
        <div class="stat-info"><p class="stat-label">Draft</p><p class="stat-value">@Model.DraftOpportunitiesCount</p></div>
    </div>
    <div class="dash-stat-card">
        <div class="stat-icon stat-icon-red"><i class="fa-solid fa-xmark"></i></div>
        <div class="stat-info"><p class="stat-label">Closed</p><p class="stat-value">@Model.ClosedOpportunitiesCount</p></div>
    </div>
</div>

<div class="dash-table-card">
    <table class="dash-table">
        <thead>
            <tr>
                <th>Opportunity</th>
                <th>Type</th>
                <th>Location</th>
                <th>Deadline</th>
                <th>Applicants</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Opportunities)
            {
                var statusCls = item.Status?.ToLower() switch { "active" or "live" => "badge-green", "draft" => "badge-gray", "closed" => "badge-red", _ => "badge-amber" };
                <tr>
                    <td><div class="table-name-cell"><strong>@item.Title</strong><span>@item.OpportunityType</span></div></td>
                    <td><span class="badge badge-blue">@item.OpportunityType</span></td>
                    <td>@item.Location</td>
                    <td style="font-size:0.82rem;color:var(--color-text-light);">@item.Deadline</td>
                    <td><strong>@item.ApplicationCount</strong></td>
                    <td><span class="badge @statusCls">@item.Status</span></td>
                    <td>
                        <div style="display:flex;gap:0.6rem;align-items:center;">
                            <a href="/Employer/EditOpportunity?id=@item.Id" class="table-action-link">
                                <i class="fa-solid fa-pen-to-square"></i> Edit
                            </a>
                            <a href="/Employer/ViewApplicants?OpportunityId=@item.Id" class="table-action-link">
                                <i class="fa-solid fa-users"></i> Applicants
                            </a>
                            <form method="post" asp-page-handler="Delete" style="display:inline;" onsubmit="return confirm('Delete this opportunity?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="table-action-link table-action-danger" style="background:none;border:none;cursor:pointer;font-family:inherit;">
                                    <i class="fa-solid fa-trash"></i> Delete
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>